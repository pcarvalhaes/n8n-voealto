/* ==========================================
   VOE ALTO CONSULTORIA — Styles
   ========================================== */

/* ==========================================
   RESET & BASE
   ========================================== */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  /* Brand Colors */
  --cream: #FAF8F5;
  --cream-dark: #F2EDE6;
  --gold: #C9A227;
  --gold-dark: #A68A1F;
  --gold-light: #E8C445;
  --charcoal: #1A1A1A;
  --charcoal-mid: #2C2C2C;
  --charcoal-light: #5A5A5A;
  --white: #FFFFFF;

  /* Design Tokens */
  --shadow-sm: 0 2px 8px rgba(0,0,0,0.06);
  --shadow-md: 0 8px 30px rgba(0,0,0,0.09);
  --shadow-lg: 0 20px 60px rgba(0,0,0,0.12);
  --shadow-gold: 0 8px 30px rgba(201, 162, 39, 0.25);

  --radius-sm: 8px;
  --radius-md: 16px;
  --radius-lg: 24px;
  --radius-full: 999px;

  --transition-fast: 0.2s ease;
  --transition-base: 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  --transition-slow: 0.6s cubic-bezier(0.16, 1, 0.3, 1);

  /* Typography */
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-body);
  background-color: var(--cream);
  color: var(--charcoal-mid);
  line-height: 1.65;
  overflow-x: hidden;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  text-decoration: none;
  color: inherit;
}

ul {
  list-style: none;
}

/* ==========================================
   EFFECTS & GLOBAL UTILS
   ========================================== */
.bg-noise {
  position: relative;
}

.bg-noise::before {
  content: "";
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0.03;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  z-index: 1;
}

.glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.glass-dark {
  background: rgba(18, 18, 20, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

/* ==========================================
   TYPOGRAPHY
   ========================================== */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-display);
  font-weight: 500;
  line-height: 1.15;
  color: inherit;
}

.title-display {
  font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  font-weight: 400;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.title-display em {
  font-style: italic;
  color: var(--gold);
}

.title-section {
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 500;
  letter-spacing: -0.02em;
}

.title-section em {
  font-style: italic;
  color: var(--gold);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.5rem;
}

.eyebrow::before {
  content: '';
  width: 2.5rem;
  height: 2px;
  background: var(--gold);
  border-radius: 2px;
}

.eyebrow.light {
  color: var(--gold-light);
}

.eyebrow.light::before {
  background: var(--gold-light);
}

.lead-text {
  font-size: 1.25rem;
  line-height: 1.6;
  font-weight: 400;
  color: var(--charcoal-light);
  max-width: 600px;
}

.section-subtitle {
  font-size: 1.15rem;
  line-height: 1.7;
  color: var(--charcoal-light);
  max-width: 720px;
  margin: 0 auto;
}

/* ==========================================
   CONTAINER & LAYOUT
   ========================================== */
.container {
  width: 100%;
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

@media (min-width: 768px) {
  .container {
    padding: 0 2.5rem;
  }
}

/* ==========================================
   BUTTONS
   ========================================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.9rem 2rem;
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-decoration: none;
  border-radius: var(--radius-full);
  border: 2px solid transparent;
  cursor: pointer;
  transition: var(--transition-base);
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.12);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.btn:hover::after {
  opacity: 1;
}

.btn-primary {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
  color: var(--charcoal);
  border-color: transparent;
  box-shadow: var(--shadow-gold);
}

.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 40px rgba(201, 162, 39, 0.4);
}

.btn-primary:active {
  transform: translateY(-1px);
}

.btn-outline {
  background-color: transparent;
  color: var(--charcoal-mid);
  border-color: rgba(44, 44, 44, 0.2);
}

.btn-outline:hover {
  background-color: var(--charcoal);
  color: var(--cream);
  border-color: var(--charcoal);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.btn-outline.light {
  color: var(--cream);
  border-color: rgba(250, 248, 245, 0.35);
}

.btn-outline.light:hover {
  background-color: var(--cream);
  color: var(--charcoal);
  border-color: var(--cream);
}

.btn-ghost {
  background: rgba(255,255,255,0.12);
  color: var(--cream);
  border-color: rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
}

.btn-ghost:hover {
  background: rgba(255,255,255,0.22);
  border-color: rgba(255,255,255,0.5);
  transform: translateY(-2px);
}

.btn-whatsapp {
  background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
  color: var(--white);
  border-color: transparent;
  box-shadow: 0 8px 25px rgba(37, 211, 102, 0.3);
}

.btn-whatsapp:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 35px rgba(37, 211, 102, 0.45);
}

/* ==========================================
   HEADER
   ========================================== */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 1.25rem 0;
  transition: all 0.4s ease;
}

.header.scrolled {
  background: rgba(250, 248, 245, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 1px 0 rgba(0,0,0,0.06), 0 4px 20px rgba(0,0,0,0.04);
  padding: 0.9rem 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

/* Logo */
.logo {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 400;
  color: var(--cream);
  text-decoration: none;
  transition: color var(--transition-fast);
  letter-spacing: -0.01em;
  flex-shrink: 0;
}

.logo span {
  color: var(--gold);
}

.header.scrolled .logo {
  color: var(--charcoal);
}

/* Desktop Nav */
.nav {
  display: none;
  align-items: center;
  gap: 0.25rem;
  margin: 0 auto;
}

@media (min-width: 1024px) {
  .nav {
    display: flex;
  }
}

.nav-link {
  position: relative;
  padding: 0.5rem 0.875rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: rgba(250, 248, 245, 0.85);
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast);
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2px;
  background: var(--gold);
  border-radius: 2px;
  transition: width 0.3s ease;
}

.nav-link:hover {
  color: rgba(250, 248, 245, 1);
}

.nav-link:hover::after,
.nav-link.active::after {
  width: calc(100% - 1.75rem);
}

.header.scrolled .nav-link {
  color: var(--charcoal-light);
}

.header.scrolled .nav-link:hover {
  color: var(--charcoal);
}

/* Header CTA */
.header-cta {
  display: none;
  padding: 0.65rem 1.5rem;
  font-size: 0.85rem;
}

@media (min-width: 1024px) {
  .header-cta {
    display: inline-flex;
  }
}

/* Hamburger */
.menu-toggle {
  display: flex;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  border-radius: var(--radius-sm);
}

@media (min-width: 1024px) {
  .menu-toggle {
    display: none;
  }
}

.menu-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background-color: var(--cream);
  border-radius: 2px;
  transition: all 0.3s ease;
  transform-origin: center;
}

.header.scrolled .menu-toggle span {
  background-color: var(--charcoal);
}

.menu-toggle.active span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.menu-toggle.active span:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}

.menu-toggle.active span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* ==========================================
   MOBILE MENU
   ========================================== */
.mobile-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 199;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
}

.mobile-overlay.active {
  opacity: 1;
  pointer-events: auto;
}

.mobile-menu {
  position: fixed;
  top: 0;
  right: -100%;
  width: min(380px, 100%);
  height: 100vh;
  background: var(--charcoal);
  z-index: 200;
  transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
  box-shadow: -20px 0 60px rgba(0,0,0,0.3);
}

.mobile-menu.open {
  right: 0;
}

.mobile-menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem;
  border-bottom: 1px solid rgba(250, 248, 245, 0.08);
}

.mobile-menu-close {
  background: rgba(255,255,255,0.08);
  border: none;
  color: var(--cream);
  font-size: 1.25rem;
  cursor: pointer;
  padding: 0.5rem;
  border-radius: var(--radius-sm);
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--transition-fast);
}

.mobile-menu-close:hover {
  background: rgba(255,255,255,0.15);
}

.mobile-menu-nav {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 1.5rem;
  gap: 0.25rem;
  overflow-y: auto;
}

.mobile-nav-link {
  display: block;
  padding: 1rem 0.75rem;
  font-family: var(--font-display);
  font-size: 1.4rem;
  color: rgba(250, 248, 245, 0.85);
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast);
}

.mobile-nav-link:hover {
  color: var(--gold);
  background: rgba(201, 162, 39, 0.08);
  padding-left: 1.25rem;
}

.mobile-menu-footer {
  padding: 1.5rem;
  border-top: 1px solid rgba(250, 248, 245, 0.08);
}

/* ==========================================
   HERO CAROUSEL
   ========================================== */
.hero {
  position: relative;
  height: 100vh;
  min-height: 620px;
  overflow: hidden;
}

.hero-slides {
  position: relative;
  width: 100%;
  height: 100%;
}

.hero-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 1s ease;
}

.hero-slide.active {
  opacity: 1;
  z-index: 1;
}

.hero-slide-bg {
  position: absolute;
  inset: 0;
}

.hero-slide-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

@keyframes kenBurns {
  0%   { transform: scale(1); }
  100% { transform: scale(1.08); }
}

.hero-slide.active .hero-slide-bg img {
  animation: kenBurns 14s ease-in-out forwards;
}

.hero-slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    rgba(20, 18, 14, 0.88) 0%,
    rgba(20, 18, 14, 0.6) 55%,
    rgba(20, 18, 14, 0.25) 100%
  );
}

.hero-slide-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  align-items: center;
  padding-top: 6rem;
}

.hero-text {
  max-width: 640px;
}

.hero-badge {
  display: inline-block;
  padding: 0.35rem 1rem;
  background: rgba(201, 162, 39, 0.2);
  border: 1px solid rgba(201, 162, 39, 0.4);
  color: var(--gold-light);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  border-radius: var(--radius-full);
  backdrop-filter: blur(8px);
  margin-bottom: 1.5rem;
  animation: fadeInDown 0.6s ease both;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-text .title-display {
  color: var(--cream);
  margin-bottom: 1.25rem;
  animation: fadeInUp 0.7s 0.1s ease both;
}

.hero-text p {
  color: rgba(250, 248, 245, 0.78);
  font-size: 1.1rem;
  line-height: 1.75;
  margin-bottom: 2.5rem;
  animation: fadeInUp 0.7s 0.2s ease both;
  max-width: 520px;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  animation: fadeInUp 0.7s 0.3s ease both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Hero Nav */
.hero-nav {
  position: absolute;
  bottom: 2.5rem;
  left: 0;
  right: 0;
  z-index: 10;
}

.hero-nav-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-dots {
  display: flex;
  gap: 0.75rem;
  align-items: center;
}

.hero-dot {
  width: 8px;
  height: 8px;
  border-radius: var(--radius-full);
  background: rgba(250, 248, 245, 0.35);
  border: none;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.hero-dot.active {
  background: var(--gold);
  width: 28px;
  box-shadow: 0 0 12px rgba(201, 162, 39, 0.6);
}

/* Scroll Indicator */
.hero-scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  right: 2.5rem;
  z-index: 10;
  display: none;
}

@media (min-width: 768px) {
  .hero-scroll-indicator {
    display: block;
  }
}

.hero-scroll-line {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, rgba(250,248,245,0.6), transparent);
  margin: 0 auto;
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(1.1); }
}

/* ==========================================
   METRICS STRIP
   ========================================== */
.metrics-strip {
  background: var(--charcoal);
  padding: 3rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.metrics-grid {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
}

.metric-item {
  text-align: center;
  padding: 1rem 2.5rem;
  flex: 1;
  min-width: 140px;
}

.metric-number {
  display: block;
  font-family: var(--font-display);
  font-size: 2.8rem;
  font-weight: 500;
  color: var(--gold);
  line-height: 1;
  letter-spacing: -0.02em;
}

.metric-suffix {
  font-family: var(--font-display);
  font-size: 1.8rem;
  color: var(--gold-light);
}

.metric-label {
  font-size: 0.78rem;
  color: rgba(250, 248, 245, 0.55);
  margin-top: 0.4rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 500;
}

.metric-divider {
  width: 1px;
  height: 50px;
  background: rgba(255,255,255,0.08);
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .metric-divider { display: none; }
  .metric-item { padding: 1rem 1.5rem; }
}

/* ==========================================
   SECTIONS
   ========================================== */
.section {
  padding: 5rem 0;
}

@media (min-width: 768px) {
  .section {
    padding: 7rem 0;
  }
}

.section-dark {
  background: var(--charcoal);
  color: var(--cream);
}

.section-header-centered {
  text-align: center;
  margin-bottom: 4rem;
}

.section-header-centered .eyebrow {
  justify-content: center;
  margin-bottom: 1rem;
}

.section-header-centered .title-section {
  margin-bottom: 1.25rem;
}

/* ==========================================
   SPLIT GRID (BPO / RECRUTAMENTO)
   ========================================== */
.split-grid {
  display: grid;
  gap: 3rem;
  align-items: center;
}

@media (min-width: 1024px) {
  .split-grid {
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .split-grid.reverse {
    direction: rtl;
  }

  .split-grid.reverse > * {
    direction: ltr;
  }
}

.split-content .eyebrow {
  margin-bottom: 1.25rem;
  display: block;
}

.split-content .title-section {
  margin-bottom: 1.25rem;
}

.split-content .lead-text {
  margin-bottom: 2rem;
}

/* Benefit List */
.benefit-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  margin-bottom: 2.5rem;
}

.benefit-list li {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.95rem;
  color: var(--charcoal-light);
}

.benefit-check {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--charcoal);
  border-radius: 50%;
  font-size: 0.65rem;
  font-weight: 700;
  flex-shrink: 0;
}

/* ==========================================
   SERVICE CARDS (BPO)
   ========================================== */
.services-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.service-card {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.35rem;
  background: var(--white);
  border: 1px solid rgba(0, 0, 0, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: var(--transition-base);
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--gold), var(--gold-light));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.service-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md), 0 0 0 1px rgba(201, 162, 39, 0.12);
}

.service-card:hover::before {
  opacity: 1;
}

.service-card--wide {
  grid-column: 1 / -1;
}

.service-card-icon {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 162, 39, 0.1);
  color: var(--gold);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  transition: var(--transition-fast);
}

.service-card:hover .service-card-icon {
  background: var(--gold);
  color: var(--white);
  transform: scale(1.05);
}

.service-card-body h3 {
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--charcoal-mid);
  margin-bottom: 0.3rem;
}

.service-card-body p {
  font-size: 0.8rem;
  color: var(--charcoal-light);
  line-height: 1.5;
  margin: 0;
}

/* ==========================================
   MARQUEE (Client Logos)
   ========================================== */
.marquee-container {
  overflow: hidden;
  padding: 3rem 0;
  background: var(--white);
  border-top: 1px solid var(--cream-dark);
  border-bottom: 1px solid var(--cream-dark);
  position: relative;
}

.marquee-content {
  display: flex;
  gap: 5rem;
  animation: marquee 30s linear infinite;
  width: max-content;
}

.marquee-item {
  height: 40px;
  opacity: 0.5;
  filter: grayscale(1);
  transition: all 0.3s ease;
}

.marquee-item:hover {
  opacity: 1;
  filter: grayscale(0);
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ==========================================
   RH SERVICES (Recrutamento)
   ========================================== */
.rh-services-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .rh-services-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.rh-service-card {
  padding: 2rem;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-md);
  text-align: center;
  transition: var(--transition-base);
}

.rh-service-card:hover {
  background: rgba(255, 255, 255, 0.06);
  transform: translateY(-5px);
  border-color: var(--gold);
}

.rh-service-card-icon {
  width: 50px;
  height: 50px;
  margin: 0 auto 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 162, 39, 0.15);
  color: var(--gold);
  border-radius: var(--radius-sm);
  font-size: 1.25rem;
}

.rh-service-card h3 {
  font-size: 1.1rem;
  margin-bottom: 1rem;
  color: var(--white);
}

.rh-service-card p {
  font-size: 0.9rem;
  color: rgba(250, 248, 245, 0.65);
  line-height: 1.6;
}

/* ==========================================
   MENTORIA SECTION
   ========================================== */
.mentoria-section {
  background: var(--cream-dark);
}

.mentoria-programs {
  display: grid;
  gap: 2rem;
}

@media (min-width: 768px) {
  .mentoria-programs {
    grid-template-columns: 1fr 1fr;
  }
}

.mentoria-card {
  padding: 2.5rem;
  background: var(--white);
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: var(--transition-base);
  position: relative;
  overflow: hidden;
}

.mentoria-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}

.mentoria-card--featured {
  border: 2px solid var(--gold);
  background: linear-gradient(145deg, #fff 80%, rgba(201,162,39,0.04) 100%);
  box-shadow: var(--shadow-gold);
}

.mentoria-card--featured:hover {
  box-shadow: 0 24px 70px rgba(201, 162, 39, 0.25);
}

.mentoria-card-badge-top {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--charcoal);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 0.3rem 0.875rem;
  border-radius: var(--radius-full);
}

.mentoria-card-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.25rem;
}

.mentoria-number {
  font-family: var(--font-display);
  font-size: 3.5rem;
  color: rgba(201, 162, 39, 0.2);
  font-weight: 700;
  line-height: 1;
}

.mentoria-badge {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  background: rgba(201, 162, 39, 0.12);
  color: var(--gold-dark);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  border-radius: var(--radius-full);
}

.mentoria-card h3 {
  font-size: 1.7rem;
  color: var(--charcoal);
  margin-bottom: 0.75rem;
}

.mentoria-card h3 span {
  color: var(--gold);
}

.mentoria-card p {
  color: var(--charcoal-light);
  font-size: 0.95rem;
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.mentoria-includes {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 2rem;
}

.mentoria-includes li {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  font-size: 0.875rem;
  color: var(--charcoal-light);
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(0,0,0,0.04);
}

.mentoria-includes li::before {
  content: '✓';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  background: rgba(201, 162, 39, 0.15);
  color: var(--gold-dark);
  border-radius: 50%;
  font-size: 0.6rem;
  font-weight: 700;
  flex-shrink: 0;
}

/* ==========================================
   SOLUÇÕES SECTION
   ========================================== */
.solucoes-grid {
  display: grid;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .solucoes-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.solucao-card {
  padding: 2.5rem 2rem;
  background: rgba(250, 248, 245, 0.04);
  border: 1px solid rgba(250, 248, 245, 0.07);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(12px);
  transition: var(--transition-base);
}

.solucao-card:hover {
  background: rgba(250, 248, 245, 0.07);
  border-color: rgba(201, 162, 39, 0.3);
  transform: translateY(-6px);
  box-shadow: 0 16px 50px rgba(0,0,0,0.25);
}

.solucao-icon {
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 162, 39, 0.15);
  color: var(--gold);
  border-radius: var(--radius-md);
  margin-bottom: 1.75rem;
  transition: var(--transition-fast);
}

.solucao-card:hover .solucao-icon {
  background: var(--gold);
  color: var(--charcoal);
  transform: scale(1.08);
}

.solucao-card h3 {
  font-size: 1.4rem;
  color: var(--cream);
  margin-bottom: 1rem;
}

.solucao-card p {
  color: rgba(250, 248, 245, 0.65);
  font-size: 0.9375rem;
  line-height: 1.7;
  margin-bottom: 1.75rem;
}

.solucao-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--gold);
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  transition: gap 0.3s ease, color 0.2s ease;
}

.solucao-link:hover {
  gap: 0.875rem;
  color: var(--gold-light);
}

/* ==========================================
   SOBRE SECTION
   ========================================== */
.sobre-section {
  background: var(--cream);
}

.sobre-grid {
  display: grid;
  gap: 4rem;
  align-items: center;
}

@media (min-width: 1024px) {
  .sobre-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.sobre-content .eyebrow {
  display: block;
  margin-bottom: 1.25rem;
}

.sobre-content .title-section {
  margin-bottom: 1.5rem;
}

.sobre-content p {
  color: var(--charcoal-light);
  font-size: 1rem;
  line-height: 1.8;
  margin-bottom: 1.25rem;
}

.sobre-values {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 2rem;
}

.sobre-value {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1.1rem;
  background: var(--white);
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: var(--radius-full);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--charcoal-mid);
  box-shadow: var(--shadow-sm);
  transition: var(--transition-fast);
}

.sobre-value:hover {
  border-color: var(--gold);
  color: var(--gold-dark);
}

.sobre-value-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: rgba(201, 162, 39, 0.12);
  border-radius: 50%;
  color: var(--gold-dark);
  flex-shrink: 0;
}

.sobre-visual {
  display: flex;
  justify-content: center;
}

.sobre-visual-card {
  position: relative;
  background: var(--charcoal);
  border-radius: var(--radius-lg);
  padding: 3rem;
  max-width: 420px;
  width: 100%;
  overflow: hidden;
}

.sobre-quote {
  position: relative;
  z-index: 1;
  font-family: var(--font-display);
  font-size: 1.3rem;
  color: var(--cream);
  line-height: 1.6;
  font-style: italic;
  font-weight: 400;
}

.sobre-quote::before {
  content: '"';
  font-size: 5rem;
  color: var(--gold);
  opacity: 0.3;
  line-height: 0.5;
  display: block;
  margin-bottom: 0.5rem;
  font-family: var(--font-display);
}

.sobre-visual-bg {
  position: absolute;
  right: -0.5rem;
  bottom: -1.5rem;
  font-family: var(--font-display);
  font-size: 12rem;
  font-weight: 700;
  color: rgba(201, 162, 39, 0.07);
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

/* ==========================================
   CTA FULL SECTION
   ========================================== */
.cta-full {
  padding: 6rem 0;
}

.cta-full-inner {
  text-align: center;
}

.cta-full-text .eyebrow {
  margin-bottom: 1rem;
  display: block;
}

.cta-full-text .title-section {
  margin-bottom: 1rem;
}

.cta-full-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

/* ==========================================
   CONTACT FORM SECTION
   ========================================== */
.form-grid {
  display: grid;
  gap: 3.5rem;
  align-items: start;
}

@media (min-width: 1024px) {
  .form-grid {
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
  }
}

.form-info .eyebrow {
  display: block;
  margin-bottom: 1.25rem;
}

.form-info .title-section {
  margin-bottom: 1.5rem;
}

.form-info .lead-text {
  margin-bottom: 2.5rem;
}

.form-trust-signals {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2.5rem;
}

.trust-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.trust-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  background: rgba(201, 162, 39, 0.1);
  border-radius: var(--radius-sm);
  color: var(--gold-dark);
  flex-shrink: 0;
}

.trust-item strong {
  display: block;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--charcoal-mid);
  margin-bottom: 0.15rem;
}

.trust-item p {
  font-size: 0.82rem;
  color: var(--charcoal-light);
  margin: 0;
}

.form-contact-items {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.form-contact-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.1rem 1.25rem;
  background: var(--white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(0, 0, 0, 0.04);
  transition: var(--transition-fast);
  text-decoration: none;
  color: inherit;
}

.form-contact-item:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: rgba(201, 162, 39, 0.2);
}

.form-contact-icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 162, 39, 0.1);
  color: var(--gold);
  flex-shrink: 0;
  transition: var(--transition-fast);
}

.form-contact-item:hover .form-contact-icon {
  background: var(--gold);
  color: var(--white);
}

.form-contact-item h4 {
  font-family: var(--font-body);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--charcoal-light);
  margin-bottom: 0.18rem;
}

.form-contact-item p {
  font-size: 0.9rem;
  color: var(--charcoal-mid);
  font-weight: 500;
  margin: 0;
}

/* ==========================================
   FORM STYLES
   ========================================== */
.contact-form {
  background: var(--white);
  padding: 2.5rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 1px solid rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

@media (min-width: 480px) {
  .contact-form {
    padding: 3rem;
  }
}

.form-group {
  position: relative;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 1.1rem 1rem;
  padding-top: 1.5rem;
